{
  "name": "react-variant-switcher",
  "version": "0.1.0",
  "description": "Switch between React UI variants using declarative Option blocks.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "react",
    "design",
    "variants",
    "switcher",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lorenzkrinner/react-variant-switcher.git"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "build": "tsup && node scripts/build-styles.js",
    "build:styles": "node scripts/build-styles.js",
    "clean": "rm -rf dist coverage",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublish": "pnpm run clean && pnpm run lint && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "react-variant-switcher": "link:"
  }
}
